NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
API_BASE_URL_INTERNAL=http://backend:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/propspace
POSTGRES_DB=propspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
SESSION_COOKIE_NAME=propspace_session
SESSION_COOKIE_SECURE=false
OTP_EXPIRY_MINUTES=5
OTP_RESEND_SECONDS=60
ALLOW_DEV_OTP_PREVIEW=true
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
